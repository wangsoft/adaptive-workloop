#!/usr/bin/env python3
"""Run deterministic package, script, eval, and behavior-regression checks."""

from __future__ import annotations

import json
import os
import py_compile
import re
import subprocess
import sys
import tempfile
from datetime import date
from pathlib import Path


ROOT = Path(__file__).resolve().parent.parent
SCRIPT_NAMES = (
    "probe-capabilities",
    "create-episode",
    "verify-contract",
    "episode-state",
    "check-episode",
    "run-evals",
    "grade-evals",
    "compare-evals",
    "run-matrix",
    "decide-promotion",
    "check",
)
PYTHON_MODULES = ("workloop_core.py",)
ADAPTER_SCRIPTS = ("codex-cli", "claude-code", "codex-grader", "claude-grader")
ADAPTER_MODULES = ("provider_common.py",)
LEGACY_PATTERNS = {
    "legacy executable Markdown contract": re.compile(
        r"desc\s*::\s*(?:command|cmd)|- \[ \].*::"
    ),
    "legacy episode directory": re.compile(r"\.workloop/episodes"),
    "legacy strict flag": re.compile(r"verify-contract[^\n]*--strict"),
    "obsolete Bash-only compatibility": re.compile(r"bash 3\.2", re.IGNORECASE),
}


def fail(message: str) -> None:
    print(f"check: FAIL — {message}", file=sys.stderr)
    raise SystemExit(1)


def run(*argv: str, env: dict[str, str] | None = None) -> None:
    result = subprocess.run(
        argv, cwd=ROOT, text=True, capture_output=True, check=False, env=env
    )
    if result.returncode != 0:
        print(result.stdout, end="")
        print(result.stderr, end="", file=sys.stderr)
        fail("command failed: " + " ".join(argv))
    if result.stdout:
        print(result.stdout, end="")


def validate_frontmatter() -> None:
    skill = (ROOT / "SKILL.md").read_text(encoding="utf-8")
    if not skill.startswith("---\n") or skill.count("---") < 2:
        fail("SKILL.md frontmatter is missing")
    frontmatter = skill.split("---", 2)[1]
    if not re.search(r"(?m)^name: adaptive-workloop$", frontmatter):
        fail("SKILL.md name does not match directory")
    if not re.search(r"(?m)^description: \".+\"$", frontmatter):
        fail("SKILL.md needs a one-line quoted description")
    if re.search(r"(?m)^compatibility:", frontmatter):
        fail(
            "top-level compatibility is not accepted by the Codex validator; keep it in metadata"
        )
    if len(skill.splitlines()) > 500 or len(skill.split()) > 5000:
        fail("SKILL.md exceeds progressive-disclosure budget")
    openai_yaml = ROOT / "agents" / "openai.yaml"
    if not openai_yaml.is_file():
        fail("agents/openai.yaml is missing")
    interface = openai_yaml.read_text(encoding="utf-8")
    if "display_name:" not in interface or "short_description:" not in interface:
        fail("agents/openai.yaml interface metadata is incomplete")
    if "$adaptive-workloop" not in interface:
        fail("agents/openai.yaml default_prompt must mention $adaptive-workloop")


def validate_json() -> None:
    paths = sorted((ROOT / "evals").glob("*.json"))
    paths.extend(
        [ROOT / "assets" / "checks.json", ROOT / "references" / "model-deltas.json"]
    )
    for path in paths:
        try:
            json.loads(path.read_text(encoding="utf-8"))
        except json.JSONDecodeError as exc:
            fail(f"invalid JSON in {path.relative_to(ROOT)}: {exc}")
    ledger = json.loads(
        (ROOT / "references" / "model-deltas.json").read_text(encoding="utf-8")
    )
    if ledger.get("schema") != "workloop-model-deltas/1" or not isinstance(
        ledger.get("entries"), list
    ):
        fail("model-deltas.json has an invalid schema")
    for entry in ledger["entries"]:
        required = {
            "id",
            "model_pattern",
            "host_pattern",
            "observed",
            "evidence",
            "counter_instruction",
            "status",
            "retest_by",
        }
        if not isinstance(entry, dict) or not required.issubset(entry):
            fail("model-deltas.json entry is missing required fields")
        if entry["status"] not in {"active", "retired"}:
            fail(f"model delta {entry['id']} has invalid status")
        if len(str(entry["counter_instruction"]).splitlines()) > 3:
            fail(
                f"model delta {entry['id']} exceeds the three-line counter-instruction limit"
            )
        if not isinstance(entry["evidence"], list) or len(entry["evidence"]) < 1:
            fail(f"model delta {entry['id']} has no evidence")
        try:
            expiry = date.fromisoformat(entry["retest_by"])
        except (TypeError, ValueError):
            fail(f"model delta {entry['id']} has invalid retest_by")
        if entry["status"] == "active" and expiry < date.today():
            fail(f"model delta {entry['id']} is active but expired")


def validate_scripts() -> None:
    with tempfile.TemporaryDirectory(prefix="adaptive-workloop-check-") as tmp:
        compile_dir = Path(tmp)
        for name in SCRIPT_NAMES:
            path = ROOT / "scripts" / name
            if not path.is_file():
                fail(f"missing script: scripts/{name}")
            if not os.access(path, os.X_OK):
                fail(f"script is not executable: scripts/{name}")
            if (
                path.read_text(encoding="utf-8").splitlines()[0]
                != "#!/usr/bin/env python3"
            ):
                fail(f"unexpected interpreter: scripts/{name}")
            try:
                py_compile.compile(
                    str(path),
                    cfile=str(compile_dir / f"{name}.pyc"),
                    doraise=True,
                )
            except py_compile.PyCompileError as exc:
                fail(str(exc))
        for name in PYTHON_MODULES:
            path = ROOT / "scripts" / name
            if not path.is_file():
                fail(f"missing module: scripts/{name}")
            try:
                py_compile.compile(
                    str(path),
                    cfile=str(compile_dir / f"{name}.pyc"),
                    doraise=True,
                )
            except py_compile.PyCompileError as exc:
                fail(str(exc))
        for name in (*ADAPTER_SCRIPTS, *ADAPTER_MODULES):
            path = ROOT / "evals" / "adapters" / name
            if not path.is_file():
                fail(f"missing adapter file: evals/adapters/{name}")
            if name in ADAPTER_SCRIPTS and not os.access(path, os.X_OK):
                fail(f"adapter is not executable: evals/adapters/{name}")
            try:
                py_compile.compile(
                    str(path),
                    cfile=str(compile_dir / f"adapter-{name}.pyc"),
                    doraise=True,
                )
            except py_compile.PyCompileError as exc:
                fail(str(exc))


def validate_no_legacy_contract() -> None:
    paths = [ROOT / "SKILL.md", ROOT / "README.md", ROOT / "README.zh-CN.md"]
    paths.extend(sorted((ROOT / "assets").glob("*.md")))
    paths.extend(sorted((ROOT / "references").glob("*.md")))
    for path in paths:
        text = path.read_text(encoding="utf-8")
        for label, pattern in LEGACY_PATTERNS.items():
            if pattern.search(text):
                fail(f"{label} remains in {path.relative_to(ROOT)}")


def main() -> int:
    if sys.version_info < (3, 10):
        fail("Python 3.10+ is required")
    validate_frontmatter()
    validate_json()
    validate_scripts()
    validate_no_legacy_contract()
    run(str(ROOT / "scripts" / "run-evals"), "--validate")
    env = os.environ.copy()
    env["WORKLOOP_CHECK_INNER"] = "1"
    run(sys.executable, "-m", "unittest", "discover", "-s", "tests", "-v", env=env)
    print("check: PASS")
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
