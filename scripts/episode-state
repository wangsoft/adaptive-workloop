#!/usr/bin/env python3
"""Append an episode event and atomically update mutable state."""

from __future__ import annotations

import argparse
import fcntl
import hashlib
import json
import os
import re
import sys
from datetime import datetime, timezone
from pathlib import Path
from typing import Any

sys.dont_write_bytecode = True
from workloop_core import scan_tracked_episode, validate_episode_readiness  # noqa: E402


STATUSES = ("open", "in_progress", "blocked", "verified", "complete", "cancelled")
TRANSITIONS = {
    "open": {"in_progress", "blocked", "cancelled"},
    "in_progress": {"blocked", "verified", "cancelled"},
    "blocked": {"in_progress", "cancelled"},
    "verified": {"in_progress", "complete", "cancelled"},
    "complete": set(),
    "cancelled": set(),
}
KIND_RE = re.compile(r"^[a-z][a-z0-9_.-]{0,63}$")
ID_RE = re.compile(r"^[a-z0-9][a-z0-9-]{0,63}$")
GRADING_PATH = "evidence/grading.json"


class VerificationGateError(ValueError):
    pass


def parse_args() -> argparse.Namespace:
    parser = argparse.ArgumentParser(description=__doc__)
    parser.add_argument("episode", type=Path)
    parser.add_argument("--status", required=True, choices=STATUSES)
    parser.add_argument("--kind", default="status.changed")
    parser.add_argument("--message", default="")
    parser.add_argument("--evidence", action="append", default=[])
    return parser.parse_args()


def utc_now() -> str:
    return datetime.now(timezone.utc).strftime("%Y-%m-%dT%H:%M:%SZ")


def load_json(path: Path) -> dict[str, Any]:
    try:
        value = json.loads(path.read_text(encoding="utf-8"))
    except (OSError, json.JSONDecodeError) as exc:
        raise ValueError(f"cannot read {path.name}: {exc}") from exc
    if not isinstance(value, dict):
        raise ValueError(f"{path.name} must contain an object")
    return value


def file_digest(path: Path) -> str:
    digest = hashlib.sha256()
    with path.open("rb") as handle:
        for chunk in iter(lambda: handle.read(1024 * 1024), b""):
            digest.update(chunk)
    return "sha256:" + digest.hexdigest()


def resolve_evidence(episode: Path, value: Any) -> tuple[str, Path]:
    if not isinstance(value, str) or not value:
        raise VerificationGateError("evidence paths must be non-empty strings")
    relative = Path(value)
    if relative.is_absolute():
        raise VerificationGateError("evidence paths must be relative to the episode")
    candidate = episode / relative
    if candidate.is_symlink() or not candidate.is_file():
        raise VerificationGateError(f"evidence is not a regular file: {value}")
    resolved = candidate.resolve()
    try:
        normalized = resolved.relative_to(episode).as_posix()
    except ValueError as exc:
        raise VerificationGateError(f"evidence escapes the episode: {value}") from exc
    return normalized, resolved


def validate_grading(episode: Path, *, recorded_digest: str | None = None) -> str:
    checks_path = episode / "checks.json"
    grading_path = episode / GRADING_PATH
    try:
        checks = load_json(checks_path)
        grading = load_json(grading_path)
    except ValueError as exc:
        raise VerificationGateError(str(exc)) from exc

    digest = file_digest(grading_path)
    if recorded_digest is not None and digest != recorded_digest:
        raise VerificationGateError("grading changed after verification")
    if checks.get("schema") != "workloop-checks/1":
        raise VerificationGateError("checks.json has an invalid schema")
    if grading.get("schema") != "workloop-grading/1":
        raise VerificationGateError("grading.json has an invalid schema")
    if grading.get("checks_digest") != file_digest(checks_path):
        raise VerificationGateError("grading checks digest does not match checks.json")
    try:
        manifest = load_json(episode / "manifest.json")
    except ValueError as exc:
        raise VerificationGateError(str(exc)) from exc
    if manifest.get("schema") == "workloop-episode/3":
        if grading.get("goal_digest") != file_digest(episode / "goal.json"):
            raise VerificationGateError("grading goal digest does not match goal.json")
        if grading.get("plan_digest") != file_digest(episode / "plan.json"):
            raise VerificationGateError("grading plan digest does not match plan.json")

    expected_checks = checks.get("checks")
    expected_manual = checks.get("manual")
    results = grading.get("results")
    manual = grading.get("manual")
    summary = grading.get("summary")
    if not isinstance(expected_checks, list) or not isinstance(expected_manual, list):
        raise VerificationGateError("checks.json criteria must be arrays")
    if not isinstance(results, list) or len(results) != len(expected_checks):
        raise VerificationGateError(
            "grading results do not cover every automatic check"
        )
    if not isinstance(manual, list) or len(manual) != len(expected_manual):
        raise VerificationGateError("grading does not cover every manual criterion")
    if not isinstance(summary, dict):
        raise VerificationGateError("grading summary is missing")

    for index, (expected, result) in enumerate(
        zip(expected_checks, results, strict=True)
    ):
        if not isinstance(expected, dict) or not isinstance(result, dict):
            raise VerificationGateError(f"automatic check {index} is malformed")
        check_id = expected.get("id")
        if not isinstance(check_id, str) or not ID_RE.fullmatch(check_id):
            raise VerificationGateError(f"automatic check {index} has an invalid id")
        bound_fields = {
            "id": check_id,
            "description": str(expected.get("description", "")).strip(),
            "argv": expected.get("argv"),
            "cwd": expected.get("cwd", "."),
            "risk": expected.get("risk", "workspace-local"),
            "expected_exit": expected.get("expected_exit", 0),
        }
        if any(result.get(key) != value for key, value in bound_fields.items()):
            raise VerificationGateError(
                f"grading result is not bound to check {check_id}"
            )
        if (
            result.get("passed") is not True
            or result.get("terminal") != "pass"
            or result.get("returncode") != bound_fields["expected_exit"]
            or result.get("missing_output_patterns") != []
            or result.get("error") is not None
        ):
            raise VerificationGateError(f"automatic check did not pass: {check_id}")
        try:
            check_evidence = load_json(episode / "evidence" / f"check-{check_id}.json")
        except ValueError as exc:
            raise VerificationGateError(str(exc)) from exc
        if check_evidence != result:
            raise VerificationGateError(
                f"check evidence does not match grading: {check_id}"
            )

    for index, (expected, attested) in enumerate(
        zip(expected_manual, manual, strict=True)
    ):
        if not isinstance(expected, dict) or not isinstance(attested, dict):
            raise VerificationGateError(f"manual criterion {index} is malformed")
        criterion_id = expected.get("id")
        expected_value = {
            **expected,
            "description": str(expected.get("description", "")).strip(),
            "status": expected.get("status", "open"),
        }
        if attested != expected_value or attested.get("status") != "attested":
            raise VerificationGateError(
                f"manual criterion is not attested: {criterion_id or index}"
            )

    expected_summary = {
        "auto_pass": len(expected_checks),
        "auto_fail": 0,
        "manual_attested": len(expected_manual),
        "manual_open": 0,
        "passed": True,
    }
    if any(summary.get(key) != value for key, value in expected_summary.items()):
        raise VerificationGateError("grading summary is not a strict pass")
    return digest


def validate_verified_transition(
    episode: Path, *, kind: str, evidence: list[str]
) -> dict[str, str]:
    if kind != "verification.passed":
        raise VerificationGateError(
            "verified requires --kind verification.passed and bound grading evidence"
        )
    evidence_digests: dict[str, str] = {}
    for value in evidence:
        normalized, path = resolve_evidence(episode, value)
        evidence_digests[normalized] = file_digest(path)
    if GRADING_PATH not in evidence_digests:
        raise VerificationGateError(f"verified requires --evidence {GRADING_PATH}")
    grading_digest = validate_grading(episode)
    if evidence_digests[GRADING_PATH] != grading_digest:
        raise VerificationGateError("grading evidence digest is inconsistent")
    return dict(sorted(evidence_digests.items()))


def validate_complete_transition(
    episode: Path, *, kind: str, previous_event: dict[str, Any]
) -> None:
    if kind != "episode.closed":
        raise VerificationGateError("complete requires --kind episode.closed")
    if (
        previous_event.get("status") != "verified"
        or previous_event.get("kind") != "verification.passed"
    ):
        raise VerificationGateError("complete requires a verification.passed event")
    recorded = previous_event.get("evidence_digests")
    if not isinstance(recorded, dict) or GRADING_PATH not in recorded:
        raise VerificationGateError("verified event has no bound grading digest")
    for value, digest in recorded.items():
        normalized, path = resolve_evidence(episode, value)
        if (
            normalized != value
            or not isinstance(digest, str)
            or file_digest(path) != digest
        ):
            raise VerificationGateError(f"evidence changed after verification: {value}")
    validate_grading(episode, recorded_digest=recorded[GRADING_PATH])


def atomic_write_json(path: Path, value: dict[str, Any]) -> None:
    temporary = path.with_name(path.name + f".tmp-{os.getpid()}")
    with temporary.open("w", encoding="utf-8") as handle:
        handle.write(json.dumps(value, indent=2, sort_keys=True) + "\n")
        handle.flush()
        os.fsync(handle.fileno())
    os.replace(temporary, path)
    directory = os.open(path.parent, os.O_RDONLY)
    try:
        os.fsync(directory)
    finally:
        os.close(directory)


def load_events(
    path: Path, episode_id: str | None, manifest_digest: str
) -> list[dict[str, Any]]:
    try:
        lines = path.read_text(encoding="utf-8").splitlines()
    except OSError as exc:
        raise ValueError(f"cannot read {path.name}: {exc}") from exc
    if not lines:
        raise ValueError("events.jsonl must contain at least one event")
    events: list[dict[str, Any]] = []
    previous_status: str | None = None
    for index, line in enumerate(lines, start=1):
        try:
            event = json.loads(line)
        except json.JSONDecodeError as exc:
            raise ValueError(
                f"events.jsonl line {index} is invalid JSON: {exc}"
            ) from exc
        if not isinstance(event, dict) or event.get("schema") != "workloop-event/1":
            raise ValueError(f"events.jsonl line {index} has invalid schema")
        if event.get("seq") != index:
            raise ValueError(f"events.jsonl line {index} has non-contiguous sequence")
        if event.get("status") not in TRANSITIONS:
            raise ValueError(f"events.jsonl line {index} has invalid status")
        recorded_episode = event.get("episode_id")
        if recorded_episode is not None and recorded_episode != episode_id:
            raise ValueError(f"events.jsonl line {index} belongs to another episode")
        if index > 1 and event.get("from_status") != previous_status:
            raise ValueError(f"events.jsonl line {index} breaks the status chain")
        if index == 1:
            recorded_manifest = event.get("manifest_digest")
            if recorded_manifest is not None and recorded_manifest != manifest_digest:
                raise ValueError("manifest digest does not match episode.created")
        previous_status = event["status"]
        events.append(event)
    return events


def reconcile_state(
    state_path: Path,
    events_path: Path,
    state: dict[str, Any],
    episode_id: str | None,
    manifest_digest: str,
) -> dict[str, Any]:
    events = load_events(events_path, episode_id, manifest_digest)
    durable = events[-1]
    durable_seq = durable["seq"]
    if (
        state.get("last_event_seq") != durable_seq
        or state.get("status") != durable["status"]
    ):
        state.update(
            {
                "status": durable["status"],
                "updated_at": durable.get("at"),
                "last_event_seq": durable_seq,
            }
        )
        atomic_write_json(state_path, state)
    return state


def main() -> int:
    args = parse_args()
    episode = args.episode.resolve()
    if not episode.is_dir():
        print(f"episode-state: episode not found: {episode}", file=sys.stderr)
        return 2
    if not KIND_RE.fullmatch(args.kind):
        print(
            "episode-state: --kind must be a short dotted identifier", file=sys.stderr
        )
        return 2
    if "\n" in args.message or "\r" in args.message or len(args.message) > 500:
        print(
            "episode-state: --message must be one line and at most 500 characters",
            file=sys.stderr,
        )
        return 2
    manifest_path = episode / "manifest.json"
    state_path = episode / "state.json"
    events_path = episode / "events.jsonl"
    lock_path = episode / ".state.lock"
    try:
        manifest = load_json(manifest_path)
    except ValueError as exc:
        print(f"episode-state: {exc}", file=sys.stderr)
        return 2
    manifest_digest = file_digest(manifest_path)

    with lock_path.open("a+", encoding="utf-8") as lock:
        fcntl.flock(lock.fileno(), fcntl.LOCK_EX)
        try:
            state = load_json(state_path)
            state = reconcile_state(
                state_path,
                events_path,
                state,
                manifest.get("episode_id"),
                manifest_digest,
            )
        except ValueError as exc:
            print(f"episode-state: {exc}", file=sys.stderr)
            return 2
        current = state.get("status")
        if current not in TRANSITIONS:
            print(
                f"episode-state: invalid current status: {current!r}", file=sys.stderr
            )
            return 2
        if args.status != current and args.status not in TRANSITIONS[current]:
            print(
                f"episode-state: invalid transition {current} -> {args.status}",
                file=sys.stderr,
            )
            return 1
        events = load_events(events_path, manifest.get("episode_id"), manifest_digest)
        evidence_digests: dict[str, str] = {}
        readiness_digests: dict[str, str] = {}
        try:
            if (
                args.status == "in_progress"
                and manifest.get("schema") == "workloop-episode/3"
            ):
                readiness_errors = validate_episode_readiness(episode)
                if readiness_errors:
                    raise VerificationGateError("; ".join(readiness_errors))
                readiness_digests = {
                    name: file_digest(episode / name)
                    for name in ("goal.json", "plan.json", "checks.json")
                }
            if args.status == "verified":
                evidence_digests = validate_verified_transition(
                    episode, kind=args.kind, evidence=args.evidence
                )
            elif args.status == "complete":
                validate_complete_transition(
                    episode, kind=args.kind, previous_event=events[-1]
                )
        except VerificationGateError as exc:
            gate = (
                "readiness gate"
                if args.status == "in_progress"
                else "verification gate"
            )
            print(f"episode-state: {gate}: {exc}", file=sys.stderr)
            return 1
        if args.status == "complete" and manifest.get("storage") == "tracked":
            findings = scan_tracked_episode(episode)
            if findings:
                print(
                    "episode-state: tracked episode failed redaction gate; "
                    "run check-episode for redacted findings",
                    file=sys.stderr,
                )
                return 1

        seq = int(state.get("last_event_seq", 0)) + 1
        now = utc_now()
        event = {
            "schema": "workloop-event/1",
            "seq": seq,
            "at": now,
            "episode_id": manifest.get("episode_id"),
            "kind": args.kind,
            "from_status": current,
            "status": args.status,
            "message": args.message or None,
            "evidence": args.evidence,
        }
        if evidence_digests:
            event["evidence_digests"] = evidence_digests
        if readiness_digests:
            event["readiness_digests"] = readiness_digests
            try:
                event["route"] = load_json(episode / "plan.json").get("route")
            except ValueError:
                pass
        with events_path.open("a", encoding="utf-8") as events:
            events.write(json.dumps(event, sort_keys=True) + "\n")
            events.flush()
            os.fsync(events.fileno())
        state.update({"status": args.status, "updated_at": now, "last_event_seq": seq})
        atomic_write_json(state_path, state)
        fcntl.flock(lock.fileno(), fcntl.LOCK_UN)

    print(f"episode-state: {current} -> {args.status} (event {seq})")
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
