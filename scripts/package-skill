#!/usr/bin/env python3
"""Build a deterministic, self-describing adaptive-workloop release archive."""

from __future__ import annotations

import argparse
import hashlib
import json
import os
import re
import shutil
import sys
import tempfile
import zipfile
from pathlib import Path, PurePosixPath

sys.dont_write_bytecode = True
from workloop_core import (  # noqa: E402
    RELEASE_MANIFEST_SCHEMA,
    atomic_write_text,
    canonical_json_digest,
    release_file_digests,
    skill_runtime_digest,
    validate_release_manifest,
)


NAME = "adaptive-workloop"
REFERENCE_PREFIXES = (
    ".claude-plugin/",
    "agents/",
    "assets/",
    "evals/",
    "references/",
    "scripts/",
)
INLINE_CODE_RE = re.compile(r"`([^`\n]+)`")
MARKDOWN_LINK_RE = re.compile(r"\[[^\]]*\]\(([^)]+)\)")


class PackageError(ValueError):
    pass


def parse_args() -> argparse.Namespace:
    parser = argparse.ArgumentParser(description=__doc__)
    parser.add_argument(
        "--source",
        type=Path,
        default=Path(__file__).resolve().parent.parent,
        help="Skill checkout root",
    )
    parser.add_argument(
        "--output",
        type=Path,
        help="output directory (default: <source>/dist)",
    )
    return parser.parse_args()


def relative_entry(value: str) -> Path:
    pure = PurePosixPath(value)
    if (
        pure.is_absolute()
        or not pure.parts
        or any(part in {"", ".", ".."} for part in pure.parts)
    ):
        raise PackageError(f"unsafe packaging.allowlist entry: {value}")
    return Path(*pure.parts)


def collect_files(source: Path) -> list[Path]:
    allowlist = source / "packaging.allowlist"
    try:
        lines = allowlist.read_text(encoding="utf-8").splitlines()
    except OSError as exc:
        raise PackageError(f"cannot read packaging.allowlist: {exc}") from exc
    files: set[Path] = set()
    for raw in lines:
        value = raw.strip()
        if not value or value.startswith("#"):
            continue
        relative = relative_entry(value.rstrip("/"))
        path = source / relative
        if path.is_symlink() or not path.exists():
            raise PackageError(f"allowlisted path is missing or a symlink: {value}")
        candidates = [path] if path.is_file() else sorted(path.rglob("*"))
        for candidate in candidates:
            if candidate.is_symlink():
                raise PackageError(
                    f"allowlisted tree contains a symlink: {candidate.relative_to(source)}"
                )
            if (
                not candidate.is_file()
                or any(
                    part in {"__pycache__", ".ruff_cache"} for part in candidate.parts
                )
                or candidate.suffix == ".pyc"
            ):
                continue
            files.add(candidate.relative_to(source))
    return sorted(files, key=lambda path: path.as_posix())


def copy_payload(source: Path, destination: Path, files: list[Path]) -> None:
    for relative in files:
        source_path = source / relative
        target = destination / relative
        target.parent.mkdir(parents=True, exist_ok=True)
        shutil.copyfile(source_path, target)
        os.chmod(target, source_path.stat().st_mode & 0o777)


def validate_progressive_disclosure(root: Path) -> None:
    skill = (root / "SKILL.md").read_text(encoding="utf-8")
    referenced = {
        value
        for value in INLINE_CODE_RE.findall(skill)
        if value.startswith(REFERENCE_PREFIXES)
        and not any(character.isspace() for character in value)
        and "<" not in value
    }
    missing = sorted(value for value in referenced if not (root / value).exists())
    if missing:
        raise PackageError(
            f"packaged SKILL.md has missing runtime references: {missing}"
        )

    dangling_links: list[str] = []
    for markdown in sorted(root.rglob("*.md")):
        text = markdown.read_text(encoding="utf-8")
        for raw_target in MARKDOWN_LINK_RE.findall(text):
            target = raw_target.split("#", 1)[0].strip()
            if not target or "://" in target or target.startswith(("mailto:", "/")):
                continue
            resolved = (markdown.parent / target).resolve()
            try:
                resolved.relative_to(root)
            except ValueError:
                dangling_links.append(f"{markdown.relative_to(root)} -> {raw_target}")
                continue
            if not resolved.exists():
                dangling_links.append(f"{markdown.relative_to(root)} -> {raw_target}")
    if dangling_links:
        raise PackageError(f"packaged Markdown has dangling links: {dangling_links}")


def skill_version(root: Path) -> str:
    match = re.search(
        r'(?m)^\s+version:\s*"([0-9]+\.[0-9]+\.[0-9]+)"\s*$',
        (root / "SKILL.md").read_text(encoding="utf-8"),
    )
    if match is None:
        raise PackageError("SKILL.md metadata.version is missing")
    return match.group(1)


def write_release_manifest(root: Path) -> dict[str, object]:
    files = release_file_digests(root)
    manifest: dict[str, object] = {
        "schema": RELEASE_MANIFEST_SCHEMA,
        "name": NAME,
        "version": skill_version(root),
        "skill_runtime_digest": skill_runtime_digest(root),
        "payload_digest": canonical_json_digest(files),
        "files": files,
    }
    atomic_write_text(
        root / "release-manifest.json",
        json.dumps(manifest, indent=2, sort_keys=True) + "\n",
        mode=0o644,
    )
    validate_release_manifest(root)
    return manifest


def write_zip(package: Path, archive: Path) -> str:
    with zipfile.ZipFile(
        archive, "w", compression=zipfile.ZIP_DEFLATED, compresslevel=9
    ) as bundle:
        for path in sorted(package.rglob("*")):
            if not path.is_file() or path.is_symlink():
                continue
            relative = Path(NAME) / path.relative_to(package)
            info = zipfile.ZipInfo(relative.as_posix(), date_time=(1980, 1, 1, 0, 0, 0))
            info.create_system = 3
            mode = path.stat().st_mode & 0o777
            info.external_attr = ((0o100000 | mode) & 0xFFFF) << 16
            info.compress_type = zipfile.ZIP_DEFLATED
            bundle.writestr(
                info,
                path.read_bytes(),
                compress_type=zipfile.ZIP_DEFLATED,
                compresslevel=9,
            )
    digest = hashlib.sha256(archive.read_bytes()).hexdigest()
    return "sha256:" + digest


def main() -> int:
    args = parse_args()
    source = args.source.expanduser().resolve()
    output = (args.output or source / "dist").expanduser().resolve()
    if not (source / "SKILL.md").is_file():
        print(
            f"package-skill: source is not a Skill checkout: {source}", file=sys.stderr
        )
        return 2
    if output == source or source.is_relative_to(output):
        print(
            "package-skill: output must not contain the source checkout",
            file=sys.stderr,
        )
        return 2

    output.mkdir(parents=True, exist_ok=True)
    stage_parent = Path(tempfile.mkdtemp(prefix=f".{NAME}-", dir=output))
    stage = stage_parent / NAME
    stage.mkdir()
    target = output / NAME
    archive = output / f"{NAME}.zip"
    checksum = output / f"{NAME}.zip.sha256"
    try:
        files = collect_files(source)
        copy_payload(source, stage, files)
        validate_progressive_disclosure(stage)
        manifest = write_release_manifest(stage)
        if target.exists():
            shutil.rmtree(target)
        if archive.exists():
            archive.unlink()
        if checksum.exists():
            checksum.unlink()
        os.replace(stage, target)
        archive_digest = write_zip(target, archive)
        checksum.write_text(
            f"{archive_digest.removeprefix('sha256:')}  {archive.name}\n",
            encoding="utf-8",
        )
    except (OSError, PackageError, ValueError) as exc:
        print(f"package-skill: {exc}", file=sys.stderr)
        return 1
    finally:
        shutil.rmtree(stage_parent, ignore_errors=True)

    print(f"package: {target}")
    print(f"archive: {archive}")
    print(f"archive_digest: {archive_digest}")
    print(f"skill_runtime_digest: {manifest['skill_runtime_digest']}")
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
