#!/usr/bin/env python3
"""Validate eval suites and run provider-neutral adapter trials."""

from __future__ import annotations

import argparse
import hashlib
import json
import os
import platform
import re
import subprocess
import sys
from datetime import datetime, timezone
from pathlib import Path
from typing import Any

sys.dont_write_bytecode = True
from workloop_core import (  # noqa: E402
    BoundedCommandError,
    adapter_runtime_digest,
    atomic_write_text,
    canonical_json_digest,
    file_digest,
    redact_evidence_text,
    run_bounded_command,
    secure_directory,
    skill_runtime_digest,
)


SUITES = ("trigger", "behavior", "regression", "standalone")
EVIDENCE_CLASSES = ("public", "held-in", "held-out", "audit-held-out")
ROUTES = {None, "direct", "verified", "reviewed", "distributed"}
HOST_PROFILE_FIELDS = {
    "subagents",
    "browser",
    "context_budget",
    "effort_mode",
    "permission_mode",
    "native_orchestration",
    "installed_skills",
}
SAFE_ADAPTER_ENV = ("LANG", "LC_ALL", "LC_CTYPE", "PATH", "TEMP", "TMP", "TMPDIR")
ENV_NAME_RE = re.compile(r"^[A-Za-z_][A-Za-z0-9_]*$")


class EvalError(ValueError):
    pass


def parse_args() -> argparse.Namespace:
    parser = argparse.ArgumentParser(description=__doc__)
    parser.add_argument("--validate", action="store_true")
    parser.add_argument("--dry-run", action="store_true")
    parser.add_argument("--suite", choices=SUITES)
    parser.add_argument(
        "--dataset",
        type=Path,
        help="external eval dataset; requires an explicit matching --evidence-class",
    )
    parser.add_argument("--evidence-class", choices=EVIDENCE_CLASSES)
    parser.add_argument("--case", action="append", default=[])
    parser.add_argument("--adapter", type=Path)
    parser.add_argument(
        "--condition", choices=("candidate", "previous", "bare"), default="candidate"
    )
    parser.add_argument(
        "--previous-skill",
        type=Path,
        help="exact previous adaptive-workloop checkout used by --condition previous",
    )
    parser.add_argument("--model-profile", default="unspecified")
    parser.add_argument(
        "--host-profile",
        help="built-in profile id or path to a workloop-capabilities/1 manifest",
    )
    parser.add_argument("--trials", type=int, default=1)
    parser.add_argument("--timeout", type=float, default=300)
    parser.add_argument("--max-output-bytes", type=int, default=1024 * 1024)
    parser.add_argument(
        "--pass-env",
        action="append",
        default=[],
        metavar="NAME",
        help="explicitly pass one named environment variable to the adapter",
    )
    parser.add_argument("--output", type=Path)
    parser.add_argument(
        "--allow-review-required",
        action="store_true",
        help="return success when all non-error outputs only await independent review",
    )
    return parser.parse_args()


def load_json(path: Path) -> dict[str, Any]:
    try:
        value = json.loads(path.read_text(encoding="utf-8"))
    except (OSError, json.JSONDecodeError) as exc:
        raise EvalError(f"{path}: {exc}") from exc
    if not isinstance(value, dict):
        raise EvalError(f"{path}: root must be an object")
    return value


def validate_common(
    path: Path, value: dict[str, Any], suite: str
) -> list[dict[str, Any]]:
    cases = value.get("cases")
    if not isinstance(cases, list) or not cases:
        raise EvalError(f"{path}: cases must be a non-empty array")
    ids: set[str] = set()
    for index, case in enumerate(cases):
        if not isinstance(case, dict) or not isinstance(case.get("id"), str):
            raise EvalError(f"{path}: cases[{index}] needs a string id")
        if case["id"] in ids:
            raise EvalError(f"{path}: duplicate case id {case['id']}")
        ids.add(case["id"])
    if value.get("suite") != f"adaptive-workloop/{suite}":
        raise EvalError(f"{path}: suite label mismatch")
    return cases


def validate_suite(
    path: Path,
    suite: str,
    *,
    expected_evidence_class: str = "public",
    repository_visible: bool = True,
) -> dict[str, Any]:
    value = load_json(path)
    cases = validate_common(path, value, suite)
    declared_evidence_class = value.get("evidence_class")
    held_out = value.get("held_out")
    audit_holdout = value.get("audit_holdout", False)
    if repository_visible:
        if expected_evidence_class != "public":
            raise EvalError("repository datasets are public and cannot be held-out")
        if (
            declared_evidence_class not in {None, "public"}
            or held_out is True
            or audit_holdout is True
        ):
            raise EvalError(
                f"{path}: repository datasets are public and cannot claim hidden evidence"
            )
    else:
        if declared_evidence_class != expected_evidence_class:
            raise EvalError(
                f"{path}: evidence_class must match --evidence-class "
                f"{expected_evidence_class!r}"
            )
        if not isinstance(held_out, bool):
            raise EvalError(f"{path}: external dataset needs boolean held_out")
        hidden = expected_evidence_class in {"held-out", "audit-held-out"}
        audit = expected_evidence_class == "audit-held-out"
        if held_out is not hidden:
            raise EvalError(
                f"{path}: held_out must agree with evidence_class "
                f"{expected_evidence_class!r}"
            )
        if audit_holdout is not audit:
            raise EvalError(
                f"{path}: audit_holdout must agree with evidence_class "
                f"{expected_evidence_class!r}"
            )
    if suite == "trigger":
        for case in cases:
            if not isinstance(case.get("prompt"), str) or not isinstance(
                case.get("should_trigger"), bool
            ):
                raise EvalError(
                    f"{path}: trigger case {case['id']} needs prompt and boolean should_trigger"
                )
            if case.get("expected_route") not in ROUTES:
                raise EvalError(
                    f"{path}: trigger case {case['id']} has invalid expected_route"
                )
        positives = sum(case["should_trigger"] for case in cases)
        negatives = len(cases) - positives
        if positives < 8 or negatives < 8:
            raise EvalError(
                f"{path}: trigger suite needs at least 8 positive and 8 near-miss negative cases"
            )
    elif suite == "standalone":
        if not isinstance(value.get("required_host_profile"), str):
            raise EvalError(f"{path}: standalone suite needs required_host_profile")
        seen_routes = set()
        for case in cases:
            if not isinstance(case.get("setup"), dict) or not isinstance(
                case.get("expected"), dict
            ):
                raise EvalError(
                    f"{path}: case {case['id']} needs setup and expected objects"
                )
            expected = case["expected"]
            route = expected.get("route")
            if route not in ROUTES - {None}:
                raise EvalError(
                    f"{path}: standalone case {case['id']} has invalid route"
                )
            if expected.get("terminal") not in {"complete", "needs_human"}:
                raise EvalError(
                    f"{path}: standalone case {case['id']} has invalid terminal"
                )
            artifacts = expected.get("required_artifacts")
            if not isinstance(artifacts, list) or not all(
                isinstance(item, str) and item for item in artifacts
            ):
                raise EvalError(
                    f"{path}: standalone case {case['id']} needs string required_artifacts"
                )
            seen_routes.add(route)
        if seen_routes != ROUTES - {None}:
            raise EvalError(
                f"{path}: standalone suite must cover every route exactly or repeatedly"
            )
    else:
        for case in cases:
            if not isinstance(case.get("setup"), dict) or not isinstance(
                case.get("expected"), dict
            ):
                raise EvalError(
                    f"{path}: case {case['id']} needs setup and expected objects"
                )
            expected = case["expected"]
            if expected.get("route") is not None and not isinstance(
                expected.get("route"), str
            ):
                raise EvalError(f"{path}: case {case['id']} has invalid route")
            for field in ("must", "must_not"):
                criteria = expected.get(field)
                if not isinstance(criteria, list) or not all(
                    isinstance(item, str) and item for item in criteria
                ):
                    raise EvalError(
                        f"{path}: case {case['id']} needs string-array {field}"
                    )
    return value


def suite_paths(root: Path) -> dict[str, Path]:
    return {suite: root / "evals" / f"{suite}-cases.json" for suite in SUITES}


def validate_all(root: Path) -> dict[str, dict[str, Any]]:
    validated = {}
    for suite, path in suite_paths(root).items():
        validated[suite] = validate_suite(
            path, suite, expected_evidence_class="public", repository_visible=True
        )
        print(f"validate {suite}: PASS ({len(validated[suite]['cases'])} cases)")
    profile_ids = set()
    for path in sorted((root / "evals" / "profiles").glob("*.json")):
        profile = validate_host_profile(path)
        profile_ids.add(profile["profile_id"])
        print(f"validate profile {profile['profile_id']}: PASS")
    for suite, value in validated.items():
        required = value.get("required_host_profile")
        if required and required not in profile_ids:
            raise EvalError(f"suite {suite} requires missing host profile {required}")
    return validated


def resolve_dataset(
    root: Path,
    suite: str,
    dataset_arg: Path | None,
    evidence_class_arg: str | None,
    repository_suites: dict[str, dict[str, Any]],
) -> tuple[Path, dict[str, Any], dict[str, Any]]:
    if dataset_arg is None:
        if evidence_class_arg not in {None, "public"}:
            raise EvalError("repository datasets are public and cannot be held-out")
        path = suite_paths(root)[suite]
        value = repository_suites[suite]
        evidence_class = "public"
        origin = "repository"
    else:
        if evidence_class_arg is None:
            raise EvalError("external --dataset requires an explicit --evidence-class")
        path = dataset_arg.expanduser().resolve()
        if not path.is_file():
            raise EvalError(f"dataset not found: {path}")
        value = validate_suite(
            path,
            suite,
            expected_evidence_class=evidence_class_arg,
            repository_visible=False,
        )
        evidence_class = evidence_class_arg
        origin = "external"
    return (
        path,
        value,
        {
            "suite": suite,
            "digest": file_digest(path),
            "evidence_class": evidence_class,
            "origin": origin,
            "held_out": evidence_class in {"held-out", "audit-held-out"},
            "audit_holdout": evidence_class == "audit-held-out",
        },
    )


def validate_host_profile(path: Path) -> dict[str, Any]:
    value = load_json(path)
    if value.get("schema") != "workloop-capabilities/1":
        raise EvalError(f"{path}: host profile schema must be workloop-capabilities/1")
    if not isinstance(value.get("profile_id"), str) or not value["profile_id"]:
        raise EvalError(f"{path}: host profile needs profile_id")
    missing = HOST_PROFILE_FIELDS - value.keys()
    if missing:
        raise EvalError(f"{path}: host profile missing fields: {sorted(missing)}")
    skills = value.get("installed_skills")
    if not isinstance(skills, list) or not all(
        isinstance(item, str) for item in skills
    ):
        raise EvalError(f"{path}: installed_skills must be a string array")
    if not isinstance(value.get("subagents"), bool) or not isinstance(
        value.get("browser"), bool
    ):
        raise EvalError(f"{path}: subagents and browser must be booleans")
    return value


def load_host_profile(root: Path, requested: str | None) -> dict[str, Any] | None:
    if requested is None:
        return None
    supplied = Path(requested)
    path = (
        supplied
        if supplied.is_file()
        else root / "evals" / "profiles" / f"{requested}.json"
    )
    if not path.is_file():
        raise EvalError(f"host profile not found: {requested}")
    capabilities = validate_host_profile(path)
    return {
        "id": capabilities["profile_id"],
        "digest": "sha256:" + hashlib.sha256(path.read_bytes()).hexdigest(),
        "capabilities": capabilities,
    }


def case_prompt(suite: str, case: dict[str, Any]) -> str:
    if suite == "trigger":
        return case["prompt"]
    setup = case["setup"]
    return str(
        setup.get("task") or setup.get("prompt") or case.get("title") or case["id"]
    )


def request_for(
    root: Path,
    suite: str,
    case: dict[str, Any],
    condition: str,
    model_profile: str,
    host_profile: dict[str, Any] | None,
    trial: int,
    skill_binding: dict[str, Any],
) -> dict[str, Any]:
    request: dict[str, Any] = {
        "schema": "workloop-adapter-request/1",
        "suite": suite,
        "case_id": case["id"],
        "trial": trial,
        "condition": condition,
        "model_profile": model_profile,
        "host_profile": host_profile,
        "prompt": case_prompt(suite, case),
        "setup": case.get("setup", {}),
        "skill": None,
    }
    if condition != "bare":
        request["skill"] = {
            "name": "adaptive-workloop",
            "path": skill_binding["path"],
            "digest": skill_binding["digest"],
        }
    return request


def resolve_skill_binding(
    root: Path, condition: str, previous_skill: Path | None
) -> dict[str, Any]:
    if condition == "bare":
        return {"condition": "bare", "name": None, "digest": None, "path": None}
    if condition == "previous":
        if previous_skill is None:
            raise EvalError("--condition previous requires --previous-skill")
        skill_root = previous_skill.resolve()
    else:
        if previous_skill is not None:
            raise EvalError("--previous-skill is only valid with --condition previous")
        skill_root = root.resolve()
    if not (skill_root / "SKILL.md").is_file():
        raise EvalError(f"skill checkout is missing SKILL.md: {skill_root}")
    return {
        "condition": condition,
        "name": "adaptive-workloop",
        "digest": skill_runtime_digest(skill_root),
        "path": str(skill_root),
    }


def adapter_environment(requested: list[str]) -> tuple[dict[str, str], list[str]]:
    invalid = [name for name in requested if not ENV_NAME_RE.fullmatch(name)]
    if invalid:
        raise EvalError(f"invalid --pass-env names: {sorted(set(invalid))}")
    missing = [name for name in requested if name not in os.environ]
    if missing:
        raise EvalError(f"--pass-env names are not set: {sorted(set(missing))}")
    environment = {
        name: os.environ[name] for name in SAFE_ADAPTER_ENV if name in os.environ
    }
    passed_names = sorted(set(requested))
    for name in passed_names:
        environment[name] = os.environ[name]
    environment["PYTHONDONTWRITEBYTECODE"] = "1"
    return environment, passed_names


def grade_trigger(
    case: dict[str, Any], condition: str, response: dict[str, Any]
) -> dict[str, Any]:
    activated = response.get("activated")
    route = response.get("route")
    expected_activation = case["should_trigger"] if condition != "bare" else False
    activation_pass = activated is expected_activation
    route_expected = case.get("expected_route") if expected_activation else None
    route_pass = route_expected is None or route == route_expected
    return {
        "schema": "workloop-eval-grading/1",
        "status": "passed" if activation_pass and route_pass else "failed",
        "activation": {
            "expected": expected_activation,
            "actual": activated,
            "passed": activation_pass,
        },
        "route": {"expected": route_expected, "actual": route, "passed": route_pass},
    }


def file_sha256(path: Path) -> str:
    digest = hashlib.sha256()
    with path.open("rb") as handle:
        for chunk in iter(lambda: handle.read(1024 * 1024), b""):
            digest.update(chunk)
    return "sha256:" + digest.hexdigest()


def artifact_matches_required(path: str, required: str) -> bool:
    return path == required or path.endswith("/" + required)


def verify_artifacts(
    response: dict[str, Any], artifact_root: Path
) -> tuple[list[dict[str, str]], list[str]]:
    records = response.get("artifacts")
    if not isinstance(records, list):
        return [], ["artifacts must be an array"]

    root = artifact_root.resolve()
    verified: list[dict[str, str]] = []
    invalid: list[str] = []
    seen: set[str] = set()
    for index, record in enumerate(records):
        label = f"artifacts[{index}]"
        if not isinstance(record, dict):
            invalid.append(f"{label} must be an object with path and sha256")
            continue
        relative = record.get("path")
        claimed_digest = record.get("sha256")
        if not isinstance(relative, str) or not relative:
            invalid.append(f"{label}.path must be a non-empty relative path")
            continue
        if relative in seen:
            invalid.append(f"{label}.path is duplicated: {relative}")
            continue
        seen.add(relative)
        relative_path = Path(relative)
        if relative_path.is_absolute():
            invalid.append(f"{label}.path must be relative: {relative}")
            continue
        candidate = (root / relative_path).resolve()
        try:
            candidate.relative_to(root)
        except ValueError:
            invalid.append(f"{label}.path escapes artifact_root: {relative}")
            continue
        if not candidate.is_file():
            invalid.append(f"{label}.path is not a regular file: {relative}")
            continue
        actual_digest = file_sha256(candidate)
        if claimed_digest != actual_digest:
            invalid.append(f"{label}.sha256 does not match file: {relative}")
            continue
        verified.append({"path": relative_path.as_posix(), "sha256": actual_digest})
    return verified, invalid


def grade_standalone(
    case: dict[str, Any], response: dict[str, Any], artifact_root: Path
) -> dict[str, Any]:
    expected = case["expected"]
    activated_pass = response.get("activated") is True
    route_pass = response.get("route") == expected["route"]
    terminal_pass = response.get("terminal") == expected["terminal"]
    degradation_pass = response.get("degradation") == expected.get("degradation")

    trace = response.get("trace")
    skill_calls = trace.get("skill_calls") if isinstance(trace, dict) else None
    trace_valid = isinstance(skill_calls, list) and all(
        isinstance(item, str) for item in skill_calls
    )
    unavailable_skill_calls = (
        [item for item in skill_calls if item != "adaptive-workloop"]
        if trace_valid
        else ["<invalid-trace>"]
    )

    verified_artifacts, invalid_artifacts = verify_artifacts(response, artifact_root)
    missing_artifacts = [
        required
        for required in expected["required_artifacts"]
        if not any(
            artifact_matches_required(artifact["path"], required)
            for artifact in verified_artifacts
        )
    ]

    passed = all(
        (
            activated_pass,
            route_pass,
            terminal_pass,
            degradation_pass,
            trace_valid,
            not unavailable_skill_calls,
            not invalid_artifacts,
            not missing_artifacts,
        )
    )
    return {
        "schema": "workloop-eval-grading/1",
        "status": "passed" if passed else "failed",
        "activated": {
            "expected": True,
            "actual": response.get("activated"),
            "passed": activated_pass,
        },
        "route": {
            "expected": expected["route"],
            "actual": response.get("route"),
            "passed": route_pass,
        },
        "terminal": {
            "expected": expected["terminal"],
            "actual": response.get("terminal"),
            "passed": terminal_pass,
        },
        "degradation": {
            "expected": expected.get("degradation"),
            "actual": response.get("degradation"),
            "passed": degradation_pass,
        },
        "unavailable_skill_calls": unavailable_skill_calls,
        "verified_artifacts": verified_artifacts,
        "invalid_artifacts": invalid_artifacts,
        "missing_artifacts": missing_artifacts,
    }


def run_adapter(
    adapter: Path,
    request: dict[str, Any],
    timeout: float,
    environment: dict[str, str],
    max_output_bytes: int,
) -> tuple[dict[str, Any], str, float]:
    try:
        result = run_bounded_command(
            [str(adapter)],
            input_bytes=json.dumps(request).encode("utf-8"),
            environment=environment,
            timeout_seconds=timeout,
            max_output_bytes=max_output_bytes,
        )
    except BoundedCommandError as exc:
        raise EvalError(f"adapter {exc.kind}: {exc}") from exc
    if result.returncode != 0:
        raise EvalError(f"adapter exited {result.returncode}: {result.stderr.strip()}")
    try:
        response = json.loads(result.stdout)
    except json.JSONDecodeError as exc:
        raise EvalError(f"adapter returned invalid JSON: {exc}") from exc
    if (
        not isinstance(response, dict)
        or response.get("schema") != "workloop-adapter-response/1"
    ):
        raise EvalError("adapter response must use schema workloop-adapter-response/1")
    return response, result.stderr, result.duration_seconds


def write_json(path: Path, value: Any) -> None:
    atomic_write_text(path, json.dumps(value, indent=2, sort_keys=True) + "\n")


def main() -> int:
    args = parse_args()
    root = Path(__file__).resolve().parent.parent
    try:
        suites = validate_all(root)
    except EvalError as exc:
        print(f"run-evals: {exc}", file=sys.stderr)
        return 2
    if args.validate and args.suite is None:
        if args.dataset is not None or args.evidence_class is not None:
            print(
                "run-evals: --dataset and --evidence-class require --suite",
                file=sys.stderr,
            )
            return 2
        return 0
    if args.suite is None:
        print(
            "run-evals: --suite is required unless only --validate is used",
            file=sys.stderr,
        )
        return 2
    try:
        dataset_path, dataset_value, dataset_binding = resolve_dataset(
            root,
            args.suite,
            args.dataset,
            args.evidence_class,
            suites,
        )
    except EvalError as exc:
        print(f"run-evals: {exc}", file=sys.stderr)
        return 2
    if args.trials < 1:
        print("run-evals: --trials must be positive", file=sys.stderr)
        return 2
    if args.timeout <= 0:
        print("run-evals: --timeout must be positive", file=sys.stderr)
        return 2
    if args.max_output_bytes < 1024:
        print("run-evals: --max-output-bytes must be at least 1024", file=sys.stderr)
        return 2
    try:
        skill_binding = resolve_skill_binding(root, args.condition, args.previous_skill)
        adapter_env, passed_environment_names = adapter_environment(args.pass_env)
    except EvalError as exc:
        print(f"run-evals: {exc}", file=sys.stderr)
        return 2

    required_host_profile = dataset_value.get("required_host_profile")
    requested_host_profile = args.host_profile or required_host_profile
    try:
        host_profile = load_host_profile(root, requested_host_profile)
    except EvalError as exc:
        print(f"run-evals: {exc}", file=sys.stderr)
        return 2
    if required_host_profile and (
        host_profile is None or host_profile["id"] != required_host_profile
    ):
        print(
            f"run-evals: suite {args.suite} requires host profile {required_host_profile}",
            file=sys.stderr,
        )
        return 2

    selected = dataset_value["cases"]
    if args.case:
        wanted = set(args.case)
        selected = [case for case in selected if case["id"] in wanted]
        missing = wanted - {case["id"] for case in selected}
        if missing:
            print(f"run-evals: unknown cases: {sorted(missing)}", file=sys.stderr)
            return 2
    requests = [
        request_for(
            root,
            args.suite,
            case,
            args.condition,
            args.model_profile,
            host_profile,
            trial,
            skill_binding,
        )
        for case in selected
        for trial in range(1, args.trials + 1)
    ]
    if args.dry_run or args.adapter is None:
        for request in requests:
            print(json.dumps(request, sort_keys=True))
        if args.adapter is None and not args.dry_run:
            print(
                "run-evals: no adapter supplied; emitted dry-run requests only",
                file=sys.stderr,
            )
        return 0

    output = args.output or root / "evals" / "runs" / datetime.now(
        timezone.utc
    ).strftime("%Y%m%d-%H%M%S")
    if output.exists() and any(output.iterdir()):
        print(f"run-evals: output directory is not empty: {output}", file=sys.stderr)
        return 2
    secure_directory(output)
    adapter_digest = (
        adapter_runtime_digest(args.adapter) if args.adapter.is_file() else None
    )
    manifest = {
        "schema": "workloop-eval-run/2",
        "created_at": datetime.now(timezone.utc).strftime("%Y-%m-%dT%H:%M:%SZ"),
        "suite": args.suite,
        "condition": args.condition,
        "model_profile": args.model_profile,
        "host_profile": (
            {"id": host_profile["id"], "digest": host_profile["digest"]}
            if host_profile
            else None
        ),
        "skill": {
            "condition": skill_binding["condition"],
            "name": skill_binding["name"],
            "digest": skill_binding["digest"],
        },
        "adapter": {
            "name": args.adapter.name,
            "digest": adapter_digest,
        },
        "dataset": {
            **dataset_binding,
            "case_ids": [case["id"] for case in selected],
        },
        "trials": args.trials,
        "runtime": {
            "python": platform.python_version(),
            "platform": platform.platform(),
            "timeout_seconds": args.timeout,
            "max_output_bytes": args.max_output_bytes,
            "process_group_cleanup": True,
            "environment_policy": "deny-by-default",
            "passed_environment_names": passed_environment_names,
        },
    }
    manifest["digest"] = canonical_json_digest(manifest)
    write_json(output / "run-manifest.json", manifest)
    summary_cases = []
    passed = failed = review_required = errors = 0
    for index, (case, request) in enumerate(
        (
            (
                case,
                request_for(
                    root,
                    args.suite,
                    case,
                    args.condition,
                    args.model_profile,
                    host_profile,
                    trial,
                    skill_binding,
                ),
            )
            for case in selected
            for trial in range(1, args.trials + 1)
        ),
        start=1,
    ):
        artifact_id = f"case-{index:03d}"
        case_dir = output / "cases" / artifact_id
        case_dir.mkdir(parents=True)
        artifact_root = case_dir / "workspace"
        artifact_root.mkdir()
        request["artifact_root"] = str(artifact_root.resolve())
        request_path = case_dir / "request.json"
        write_json(request_path, request)
        request_digest = file_digest(request_path)
        try:
            response, stderr, duration = run_adapter(
                args.adapter,
                request,
                args.timeout,
                adapter_env,
                args.max_output_bytes,
            )
            response_path = case_dir / "response.json"
            write_json(response_path, response)
            atomic_write_text(
                case_dir / "adapter.stderr.txt",
                redact_evidence_text(stderr, environment=adapter_env),
            )
            if args.suite == "trigger":
                grading = grade_trigger(case, args.condition, response)
                if grading["status"] == "passed":
                    passed += 1
                else:
                    failed += 1
            elif args.suite == "standalone":
                grading = grade_standalone(case, response, artifact_root)
                if grading["status"] == "passed":
                    passed += 1
                else:
                    failed += 1
            else:
                grading = {
                    "schema": "workloop-eval-grading/1",
                    "status": "review_required",
                    "reason": "behavior and regression outputs require an independent grader",
                }
                review_required += 1
            grading_path = case_dir / "grading.json"
            write_json(grading_path, grading)
            summary_cases.append(
                {
                    "artifact_id": artifact_id,
                    "case_id": case["id"],
                    "trial": request["trial"],
                    "status": grading["status"],
                    "duration_seconds": round(duration, 3),
                    "usage": response.get("usage", {}),
                    "runtime": response.get("runtime", {}),
                    "request_digest": request_digest,
                    "response_digest": file_digest(response_path),
                    "grading_digest": file_digest(grading_path),
                }
            )
        except (EvalError, subprocess.TimeoutExpired) as exc:
            errors += 1
            atomic_write_text(
                case_dir / "error.txt",
                redact_evidence_text(str(exc) + "\n", environment=adapter_env),
            )
            summary_cases.append(
                {
                    "artifact_id": artifact_id,
                    "case_id": case["id"],
                    "trial": request["trial"],
                    "status": "error",
                    "request_digest": request_digest,
                }
            )

    summary = {
        "schema": "workloop-eval-summary/1",
        "suite": args.suite,
        "condition": args.condition,
        "model_profile": args.model_profile,
        "host_profile": (
            {"id": host_profile["id"], "digest": host_profile["digest"]}
            if host_profile
            else None
        ),
        "dataset": {
            "digest": file_digest(dataset_path),
            "evidence_class": dataset_binding["evidence_class"],
            "origin": dataset_binding["origin"],
        },
        "trials": args.trials,
        "total": len(summary_cases),
        "passed": passed,
        "failed": failed,
        "review_required": review_required,
        "errors": errors,
        "run_manifest_digest": manifest["digest"],
        "cases": summary_cases,
    }
    summary["digest"] = canonical_json_digest(summary)
    write_json(output / "summary.json", summary)
    print(f"run-evals: {output}")
    print(
        f"summary: {passed} passed, {failed} failed, {review_required} review required, {errors} errors"
    )
    if failed or errors:
        return 1
    if review_required and not args.allow_review_required:
        return 3
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
