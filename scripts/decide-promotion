#!/usr/bin/env python3
"""Apply a fail-closed promotion policy to bound eval comparisons."""

from __future__ import annotations

import argparse
from collections import Counter
import json
import math
import sys
from pathlib import Path
from typing import Any

sys.dont_write_bytecode = True
from workloop_core import (  # noqa: E402
    atomic_write_text,
    canonical_json_digest,
    file_digest,
)
from workloop_search import (  # noqa: E402
    SearchLedgerError,
    validate_search_ledger,
)


EVIDENCE_CLASSES = {"public", "held-in", "held-out", "audit-held-out"}


class PromotionError(ValueError):
    pass


def parse_args() -> argparse.Namespace:
    parser = argparse.ArgumentParser(description=__doc__)
    parser.add_argument("--policy", required=True, type=Path)
    parser.add_argument("--comparison", required=True, action="append", type=Path)
    parser.add_argument("--search-ledger", type=Path)
    parser.add_argument("--output", required=True, type=Path)
    return parser.parse_args()


def load_json(path: Path) -> dict[str, Any]:
    try:
        value = json.loads(path.read_text(encoding="utf-8"))
    except (OSError, json.JSONDecodeError) as exc:
        raise PromotionError(f"{path}: {exc}") from exc
    if not isinstance(value, dict):
        raise PromotionError(f"{path}: root must be an object")
    return value


def write_json(path: Path, value: dict[str, Any]) -> None:
    atomic_write_text(path, json.dumps(value, indent=2, sort_keys=True) + "\n")


def number(value: Any, label: str, *, minimum: float | None = None) -> float:
    if (
        not isinstance(value, (int, float))
        or isinstance(value, bool)
        or not math.isfinite(value)
    ):
        raise PromotionError(f"policy {label} must be a finite number")
    result = float(value)
    if minimum is not None and result < minimum:
        raise PromotionError(f"policy {label} must be at least {minimum:g}")
    return result


def validate_policy(value: dict[str, Any]) -> dict[str, Any]:
    common = {
        "schema",
        "required_evidence_classes",
        "min_total_trials_per_condition",
        "min_candidate_pass_rate",
        "min_candidate_pass_rate_delta_vs_previous",
        "max_candidate_losses_vs_previous",
        "max_combined_token_ratio_vs_previous",
        "max_combined_cost_ratio_vs_previous",
        "human_approval_required",
    }
    schema = value.get("schema")
    if schema == "workloop-promotion-policy/1":
        allowed = common
    elif schema == "workloop-promotion-policy/2":
        allowed = common | {
            "required_improvement_evidence_class",
            "min_improvement_pass_rate_delta",
            "min_improvement_paired_net_wins",
            "min_improvement_paired_win_rate_lower_95",
            "max_candidates_considered",
            "max_search_rounds",
            "max_held_out_comparisons",
            "max_audit_held_out_comparisons",
            "require_observed_model_identity",
            "require_distinct_grader_observed_model",
        }
    else:
        raise PromotionError("unsupported promotion policy schema")
    if set(value) != allowed:
        raise PromotionError(f"policy fields do not match {schema}")
    classes = value.get("required_evidence_classes")
    if (
        not isinstance(classes, list)
        or not classes
        or len(classes) != len(set(classes))
        or any(item not in EVIDENCE_CLASSES for item in classes)
    ):
        raise PromotionError("policy required_evidence_classes is invalid")
    integer_fields = (
        "min_total_trials_per_condition",
        "max_candidate_losses_vs_previous",
    )
    if schema == "workloop-promotion-policy/2":
        integer_fields += (
            "min_improvement_paired_net_wins",
            "max_candidates_considered",
            "max_search_rounds",
            "max_held_out_comparisons",
            "max_audit_held_out_comparisons",
        )
    for field in integer_fields:
        field_value = value.get(field)
        if (
            not isinstance(field_value, int)
            or isinstance(field_value, bool)
            or field_value
            < (
                1
                if field.startswith("min_")
                or field
                in {
                    "max_candidates_considered",
                    "max_search_rounds",
                    "max_held_out_comparisons",
                    "max_audit_held_out_comparisons",
                }
                else 0
            )
        ):
            raise PromotionError(f"policy {field} is invalid")
    pass_rate = number(value.get("min_candidate_pass_rate"), "min_candidate_pass_rate")
    if not 0 <= pass_rate <= 1:
        raise PromotionError("policy min_candidate_pass_rate must be between 0 and 1")
    delta = number(
        value.get("min_candidate_pass_rate_delta_vs_previous"),
        "min_candidate_pass_rate_delta_vs_previous",
    )
    if not -1 <= delta <= 1:
        raise PromotionError("policy pass-rate delta must be between -1 and 1")
    number(
        value.get("max_combined_token_ratio_vs_previous"),
        "max_combined_token_ratio_vs_previous",
        minimum=0,
    )
    cost_ratio = value.get("max_combined_cost_ratio_vs_previous")
    if cost_ratio is not None:
        number(cost_ratio, "max_combined_cost_ratio_vs_previous", minimum=0)
    if schema == "workloop-promotion-policy/2":
        if value.get("required_improvement_evidence_class") != "held-in":
            raise PromotionError(
                "v2 required_improvement_evidence_class must be held-in"
            )
        if "held-in" not in classes:
            raise PromotionError("v2 policy must require held-in evidence")
        improvement_delta = number(
            value.get("min_improvement_pass_rate_delta"),
            "min_improvement_pass_rate_delta",
        )
        if not 0 < improvement_delta <= 1:
            raise PromotionError("v2 improvement delta must be between 0 and 1")
        confidence = number(
            value.get("min_improvement_paired_win_rate_lower_95"),
            "min_improvement_paired_win_rate_lower_95",
        )
        if not 0 <= confidence <= 1:
            raise PromotionError("v2 paired confidence lower bound is invalid")
        if cost_ratio is None:
            raise PromotionError("v2 policy must enforce a numeric cost ratio")
        for field in (
            "require_observed_model_identity",
            "require_distinct_grader_observed_model",
        ):
            if value.get(field) is not True:
                raise PromotionError(f"v2 policy must set {field} to true")
    if value.get("human_approval_required") is not True:
        raise PromotionError("promotion policy must require human approval")
    return value


def validate_comparison(path: Path) -> dict[str, Any]:
    report = load_json(path)
    if report.get("schema") != "workloop-eval-comparison/1" or report.get(
        "digest"
    ) != canonical_json_digest(report, omit={"digest"}):
        raise PromotionError(f"{path}: invalid comparison digest or schema")
    conditions = report.get("conditions")
    if not isinstance(conditions, dict) or not {
        "bare",
        "previous",
        "candidate",
    }.issubset(conditions):
        raise PromotionError(f"{path}: previous comparison condition is required")
    dataset = report.get("compatible_envelope", {}).get("dataset")
    if not isinstance(dataset, dict):
        raise PromotionError(f"{path}: comparison has no dataset evidence binding")
    evidence_class = dataset.get("evidence_class")
    if (
        evidence_class not in EVIDENCE_CLASSES
        or dataset.get("held_out")
        is not (evidence_class in {"held-out", "audit-held-out"})
        or dataset.get("audit_holdout", False)
        is not (evidence_class == "audit-held-out")
        or dataset.get("origin") not in {"repository", "external"}
        or (
            evidence_class in {"held-out", "audit-held-out"}
            and dataset.get("origin") != "external"
        )
    ):
        raise PromotionError(f"{path}: comparison evidence class is invalid")
    candidate_digest = conditions["candidate"].get("skill_digest")
    previous_digest = conditions["previous"].get("skill_digest")
    if not isinstance(candidate_digest, str) or not isinstance(previous_digest, str):
        raise PromotionError(
            f"{path}: comparison does not bind candidate/previous Skills"
        )
    delta = report.get("deltas", {}).get("candidate_vs_previous")
    if not isinstance(delta, dict) or not isinstance(delta.get("paired_trials"), dict):
        raise PromotionError(f"{path}: candidate_vs_previous delta is required")
    for label in ("previous", "candidate"):
        metrics = conditions[label]
        if (
            not isinstance(metrics.get("total"), int)
            or isinstance(metrics.get("total"), bool)
            or metrics["total"] < 1
            or finite_metric(metrics.get("pass_rate")) is None
            or token_total(metrics) is None
        ):
            raise PromotionError(f"{path}: invalid {label} condition metrics")
    if (
        finite_metric(delta.get("pass_rate")) is None
        or not isinstance(delta["paired_trials"].get("candidate_losses"), int)
        or isinstance(delta["paired_trials"].get("candidate_losses"), bool)
        or delta["paired_trials"]["candidate_losses"] < 0
    ):
        raise PromotionError(f"{path}: invalid candidate_vs_previous metrics")
    report["_path"] = str(path.resolve())
    report["_file_digest"] = file_digest(path)
    return report


def finite_metric(value: Any) -> float | None:
    if (
        isinstance(value, (int, float))
        and not isinstance(value, bool)
        and math.isfinite(value)
    ):
        return float(value)
    return None


def token_total(metrics: dict[str, Any]) -> int | None:
    combined = metrics.get("usage", {}).get("combined", {})
    input_tokens = combined.get("input_tokens")
    output_tokens = combined.get("output_tokens")
    if not isinstance(input_tokens, int) or not isinstance(output_tokens, int):
        return None
    return input_tokens + output_tokens


def ratio(candidate: float, previous: float) -> float | str:
    if previous == 0:
        return 1.0 if candidate == 0 else "unbounded"
    return round(candidate / previous, 6)


def observed_identity_summary(
    comparisons: list[dict[str, Any]],
) -> dict[str, Any]:
    producer_models: list[str] = []
    grader_models: list[str] = []
    producer_records = 0
    grader_records = 0
    producer_missing = 0
    grader_missing = 0
    grader_bindings: list[str] = []
    grader_binding_missing = 0
    for comparison in comparisons:
        envelope = comparison.get("compatible_envelope", {})
        producers = envelope.get("producer_runtime_identities")
        if not isinstance(producers, list) or not producers:
            producer_missing += 1
        else:
            for record in producers:
                producer_records += 1
                identity = record.get("identity") if isinstance(record, dict) else None
                observed = (
                    identity.get("observed_model")
                    if isinstance(identity, dict)
                    else None
                )
                if isinstance(observed, str) and observed.strip():
                    producer_models.append(observed.strip())
                else:
                    producer_missing += 1

        reviewer = envelope.get("reviewer")
        grader = reviewer.get("grader") if isinstance(reviewer, dict) else None
        if isinstance(grader, dict) and grader:
            grader_bindings.append(canonical_json_digest(grader))
        else:
            grader_binding_missing += 1
        observed_identities = (
            reviewer.get("observed_identities") if isinstance(reviewer, dict) else None
        )
        if not isinstance(observed_identities, list) or not observed_identities:
            grader_missing += 1
        else:
            for record in observed_identities:
                grader_records += 1
                identity = record.get("identity") if isinstance(record, dict) else None
                observed = (
                    identity.get("observed_model")
                    if isinstance(identity, dict)
                    else None
                )
                if isinstance(observed, str) and observed.strip():
                    grader_models.append(observed.strip())
                else:
                    grader_missing += 1
    return {
        "producer_models": sorted(set(producer_models)),
        "grader_models": sorted(set(grader_models)),
        "producer_records": producer_records,
        "grader_records": grader_records,
        "producer_missing": producer_missing,
        "grader_missing": grader_missing,
        "grader_bindings": sorted(set(grader_bindings)),
        "grader_binding_missing": grader_binding_missing,
    }


def normalized_proposal_binding(
    comparison: dict[str, Any],
) -> dict[str, Any] | None:
    binding = comparison.get("compatible_envelope", {}).get("proposal_validation")
    if binding is None:
        return None
    required = {
        "digest",
        "validator_digest",
        "proposal_digest",
        "registry_digest",
        "base_skill_digest",
        "candidate_skill_digest",
        "surface_id",
        "actual_changed_paths",
        "search",
        "budgets",
    }
    if not isinstance(binding, dict) or not required.issubset(binding):
        raise PromotionError("comparison has an invalid proposal validation binding")
    previous_digest = comparison["conditions"]["previous"]["skill_digest"]
    candidate_digest = comparison["conditions"]["candidate"]["skill_digest"]
    if (
        binding.get("base_skill_digest") != previous_digest
        or binding.get("candidate_skill_digest") != candidate_digest
    ):
        raise PromotionError("proposal validation does not bind comparison Skills")
    for field in (
        "digest",
        "validator_digest",
        "proposal_digest",
        "registry_digest",
        "base_skill_digest",
        "candidate_skill_digest",
    ):
        if not isinstance(binding.get(field), str):
            raise PromotionError(f"proposal validation {field} is invalid")
    if (
        not isinstance(binding.get("surface_id"), str)
        or not isinstance(binding.get("actual_changed_paths"), list)
        or not binding["actual_changed_paths"]
        or not isinstance(binding.get("search"), dict)
        or not isinstance(binding.get("budgets"), dict)
    ):
        raise PromotionError("proposal validation bounded-change metadata is invalid")
    return {
        field: binding[field]
        for field in (
            "digest",
            "validator_digest",
            "proposal_digest",
            "registry_digest",
            "base_skill_digest",
            "candidate_skill_digest",
            "surface_id",
            "actual_changed_paths",
            "search",
            "budgets",
        )
    }


def append_threshold_check(
    checks: list[dict[str, Any]],
    *,
    gate: str,
    actual: Any,
    threshold: Any,
    operator: str,
    **context: Any,
) -> None:
    actual_number = finite_metric(actual)
    threshold_number = finite_metric(threshold)
    status = "inconclusive"
    if actual_number is not None and threshold_number is not None:
        if operator == ">=":
            passed = actual_number >= threshold_number
        elif operator == "<=":
            passed = actual_number <= threshold_number
        elif operator == "==":
            passed = actual_number == threshold_number
        else:
            raise PromotionError(f"unsupported threshold operator: {operator}")
        status = "passed" if passed else "failed"
    checks.append(
        {
            "gate": gate,
            "status": status,
            "actual": actual,
            "threshold": threshold,
            "operator": operator,
            **context,
        }
    )


def main() -> int:
    args = parse_args()
    output = args.output.expanduser().resolve()
    try:
        if output.exists():
            raise PromotionError(f"output already exists: {output}")
        policy_path = args.policy.expanduser().resolve()
        policy = validate_policy(load_json(policy_path))
        comparisons = [
            validate_comparison(path.expanduser().resolve()) for path in args.comparison
        ]
        candidate_digests = {
            item["conditions"]["candidate"]["skill_digest"] for item in comparisons
        }
        if len(candidate_digests) != 1:
            raise PromotionError("comparisons do not evaluate the same candidate Skill")
        previous_digests = {
            item["conditions"]["previous"]["skill_digest"] for item in comparisons
        }
        if len(previous_digests) != 1:
            raise PromotionError("comparisons do not evaluate the same previous Skill")
        policy_v2 = policy["schema"] == "workloop-promotion-policy/2"
        if policy_v2 and args.search_ledger is None:
            raise PromotionError("v2 promotion requires --search-ledger")
        try:
            search_ledger = (
                validate_search_ledger(args.search_ledger, require_closed=True)
                if args.search_ledger is not None
                else None
            )
        except SearchLedgerError as exc:
            raise PromotionError(f"invalid search ledger: {exc}") from exc
        proposal_bindings = (
            [normalized_proposal_binding(item) for item in comparisons]
            if policy_v2
            else []
        )
    except PromotionError as exc:
        print(f"decide-promotion: {exc}", file=sys.stderr)
        return 2

    observed_classes = sorted(
        {
            item["compatible_envelope"]["dataset"]["evidence_class"]
            for item in comparisons
        }
    )
    missing_classes = sorted(
        set(policy["required_evidence_classes"]) - set(observed_classes)
    )
    checks: list[dict[str, Any]] = []
    if missing_classes:
        checks.append(
            {
                "gate": "required_evidence_classes",
                "status": "inconclusive",
                "actual": observed_classes,
                "required": policy["required_evidence_classes"],
            }
        )
    else:
        checks.append(
            {
                "gate": "required_evidence_classes",
                "status": "passed",
                "actual": observed_classes,
                "required": policy["required_evidence_classes"],
            }
        )

    selected_proposal_binding: dict[str, Any] | None = None
    class_counts = Counter(
        item["compatible_envelope"]["dataset"]["evidence_class"] for item in comparisons
    )
    if policy_v2:
        available_bindings = [item for item in proposal_bindings if item is not None]
        if len(available_bindings) != len(comparisons):
            checks.append(
                {
                    "gate": "proposal_validation_binding",
                    "status": "inconclusive",
                    "actual": len(available_bindings),
                    "required": len(comparisons),
                }
            )
        else:
            binding_digests = {
                canonical_json_digest(item) for item in available_bindings
            }
            if len(binding_digests) != 1:
                checks.append(
                    {
                        "gate": "proposal_validation_binding",
                        "status": "failed",
                        "actual": sorted(binding_digests),
                        "required": "one frozen proposal binding",
                    }
                )
            else:
                selected_proposal_binding = available_bindings[0]
                checks.append(
                    {
                        "gate": "proposal_validation_binding",
                        "status": "passed",
                        "actual": selected_proposal_binding["digest"],
                        "required": "one frozen proposal binding",
                    }
                )
        duplicate_classes = {
            name: count for name, count in class_counts.items() if count != 1
        }
        checks.append(
            {
                "gate": "unique_comparison_per_evidence_class",
                "status": "failed" if duplicate_classes else "passed",
                "actual": dict(sorted(class_counts.items())),
                "threshold": 1,
                "operator": "==",
            }
        )
        assert search_ledger is not None
        ledger_comparison_digests = {
            item["digest"] for item in search_ledger["comparisons"]
        }
        supplied_comparison_digests = {item["digest"] for item in comparisons}
        selected_ledger_candidate = search_ledger.get("selected_candidate")
        ledger_binding_passed = (
            search_ledger.get("base_skill_digest") in previous_digests
            and isinstance(selected_ledger_candidate, dict)
            and selected_ledger_candidate.get("candidate_skill_digest")
            in candidate_digests
            and selected_proposal_binding is not None
            and selected_ledger_candidate.get("proposal_validation_digest")
            == selected_proposal_binding.get("digest")
            and selected_ledger_candidate.get("proposal_digest")
            == selected_proposal_binding.get("proposal_digest")
            and supplied_comparison_digests.issubset(ledger_comparison_digests)
        )
        checks.append(
            {
                "gate": "search_ledger_binding",
                "status": "passed" if ledger_binding_passed else "failed",
                "actual": {
                    "base_skill_digest": search_ledger.get("base_skill_digest"),
                    "selected_candidate_skill_digest": (
                        selected_ledger_candidate.get("candidate_skill_digest")
                        if isinstance(selected_ledger_candidate, dict)
                        else None
                    ),
                    "recorded_final_comparisons": len(
                        supplied_comparison_digests & ledger_comparison_digests
                    ),
                },
                "required": {
                    "previous_skill_digest": next(iter(previous_digests)),
                    "candidate_skill_digest": next(iter(candidate_digests)),
                    "final_comparisons": len(supplied_comparison_digests),
                },
            }
        )
        ledger_class_counts = search_ledger["evidence_class_counts"]
        append_threshold_check(
            checks,
            gate="max_held_out_comparisons",
            actual=ledger_class_counts.get("held-out", 0),
            threshold=policy["max_held_out_comparisons"],
            operator="<=",
        )
        append_threshold_check(
            checks,
            gate="max_audit_held_out_comparisons",
            actual=ledger_class_counts.get("audit-held-out", 0),
            threshold=policy["max_audit_held_out_comparisons"],
            operator="<=",
        )
        search = (
            selected_proposal_binding.get("search", {})
            if selected_proposal_binding
            else {}
        )
        append_threshold_check(
            checks,
            gate="max_candidates_considered",
            actual=search_ledger.get("candidate_count"),
            threshold=policy["max_candidates_considered"],
            operator="<=",
        )
        append_threshold_check(
            checks,
            gate="declared_candidates_considered",
            actual=search.get("candidates_considered"),
            threshold=search_ledger.get("candidate_count"),
            operator="==",
        )
        append_threshold_check(
            checks,
            gate="max_search_rounds",
            actual=search_ledger.get("max_round"),
            threshold=policy["max_search_rounds"],
            operator="<=",
        )
        append_threshold_check(
            checks,
            gate="selected_candidate_round",
            actual=search.get("round"),
            threshold=(
                selected_ledger_candidate.get("round")
                if isinstance(selected_ledger_candidate, dict)
                else None
            ),
            operator="==",
        )
        append_threshold_check(
            checks,
            gate="held_out_evaluations_before_freeze",
            actual=search.get("held_out_evaluations_before_freeze"),
            threshold=0,
            operator="<=",
        )
        append_threshold_check(
            checks,
            gate="audit_held_out_evaluations_before_freeze",
            actual=search.get("audit_held_out_evaluations_before_freeze"),
            threshold=0,
            operator="<=",
        )
        budgets = (
            selected_proposal_binding.get("budgets", {})
            if selected_proposal_binding
            else {}
        )
        ledger_resources = search_ledger["resources"]
        append_threshold_check(
            checks,
            gate="proposal_max_trials",
            actual=ledger_resources.get("trials"),
            threshold=budgets.get("max_trials"),
            operator="<=",
        )
        append_threshold_check(
            checks,
            gate="proposal_max_cost_usd",
            actual=ledger_resources.get("cost_usd"),
            threshold=budgets.get("max_cost_usd"),
            operator="<=",
        )
        append_threshold_check(
            checks,
            gate="proposal_max_duration_seconds",
            actual=ledger_resources.get("duration_seconds"),
            threshold=budgets.get("max_duration_seconds"),
            operator="<=",
        )
        identities = observed_identity_summary(comparisons)
        identity_incomplete = (
            identities["producer_records"] == 0
            or identities["grader_records"] == 0
            or identities["producer_missing"] > 0
            or identities["grader_missing"] > 0
            or identities["grader_binding_missing"] > 0
        )
        identity_drift = (
            len(identities["producer_models"]) != 1
            or len(identities["grader_models"]) != 1
            or len(identities["grader_bindings"]) != 1
        )
        checks.append(
            {
                "gate": "observed_model_identity",
                "status": (
                    "inconclusive"
                    if identity_incomplete
                    else "failed"
                    if identity_drift
                    else "passed"
                ),
                "actual": identities,
                "required": (
                    "complete, stable provider-observed producer and grader "
                    "identities with one frozen grader binding"
                ),
            }
        )
        identities_missing = (
            identities["producer_records"] == 0
            or identities["grader_records"] == 0
            or identities["producer_missing"] > 0
            or identities["grader_missing"] > 0
        )
        identity_overlap = sorted(
            set(identities["producer_models"]) & set(identities["grader_models"])
        )
        checks.append(
            {
                "gate": "distinct_grader_observed_model",
                "status": (
                    "inconclusive"
                    if identities_missing
                    else "failed"
                    if identity_overlap
                    else "passed"
                ),
                "actual": {
                    "producer_models": identities["producer_models"],
                    "grader_models": identities["grader_models"],
                    "overlap": identity_overlap,
                },
                "required": "no overlap between observed producer and grader models",
            }
        )
        improvement_class = policy["required_improvement_evidence_class"]
        improvement = [
            item
            for item in comparisons
            if item["compatible_envelope"]["dataset"]["evidence_class"]
            == improvement_class
        ]
        improvement_delta = (
            improvement[0]["deltas"]["candidate_vs_previous"]
            if len(improvement) == 1
            else {}
        )
        paired = improvement_delta.get("paired_trials", {})
        confidence = paired.get("candidate_win_rate_wilson_95")
        confidence_lower = (
            confidence[0]
            if isinstance(confidence, list)
            and len(confidence) == 2
            and finite_metric(confidence[0]) is not None
            else None
        )
        append_threshold_check(
            checks,
            gate="min_improvement_pass_rate_delta",
            actual=improvement_delta.get("pass_rate"),
            threshold=policy["min_improvement_pass_rate_delta"],
            operator=">=",
            evidence_class=improvement_class,
        )
        append_threshold_check(
            checks,
            gate="min_improvement_paired_net_wins",
            actual=paired.get("candidate_net_wins"),
            threshold=policy["min_improvement_paired_net_wins"],
            operator=">=",
            evidence_class=improvement_class,
        )
        append_threshold_check(
            checks,
            gate="min_improvement_paired_win_rate_lower_95",
            actual=confidence_lower,
            threshold=policy["min_improvement_paired_win_rate_lower_95"],
            operator=">=",
            evidence_class=improvement_class,
        )

    for comparison in comparisons:
        evidence_class = comparison["compatible_envelope"]["dataset"]["evidence_class"]
        comparison_digest = comparison["digest"]
        candidate = comparison["conditions"]["candidate"]
        previous = comparison["conditions"]["previous"]
        delta = comparison["deltas"]["candidate_vs_previous"]
        metrics = [
            (
                "min_total_trials_per_condition",
                min(candidate.get("total", -1), previous.get("total", -1)),
                policy["min_total_trials_per_condition"],
                ">=",
            ),
            (
                "min_candidate_pass_rate",
                candidate.get("pass_rate"),
                policy["min_candidate_pass_rate"],
                ">=",
            ),
            (
                "min_candidate_pass_rate_delta_vs_previous",
                delta.get("pass_rate"),
                policy["min_candidate_pass_rate_delta_vs_previous"],
                ">=",
            ),
            (
                "max_candidate_losses_vs_previous",
                delta["paired_trials"].get("candidate_losses"),
                policy["max_candidate_losses_vs_previous"],
                "<=",
            ),
        ]
        for gate, actual, threshold, operator in metrics:
            actual_number = finite_metric(actual)
            status = "inconclusive"
            if actual_number is not None:
                passed = (
                    actual_number >= float(threshold)
                    if operator == ">="
                    else actual_number <= float(threshold)
                )
                status = "passed" if passed else "failed"
            checks.append(
                {
                    "gate": gate,
                    "status": status,
                    "actual": actual,
                    "threshold": threshold,
                    "operator": operator,
                    "evidence_class": evidence_class,
                    "comparison_digest": comparison_digest,
                }
            )

        candidate_tokens = token_total(candidate)
        previous_tokens = token_total(previous)
        token_ratio = (
            ratio(candidate_tokens, previous_tokens)
            if candidate_tokens is not None and previous_tokens is not None
            else None
        )
        max_token_ratio = policy["max_combined_token_ratio_vs_previous"]
        checks.append(
            {
                "gate": "max_combined_token_ratio_vs_previous",
                "status": (
                    "inconclusive"
                    if token_ratio is None
                    else "failed"
                    if token_ratio == "unbounded" or token_ratio > max_token_ratio
                    else "passed"
                ),
                "actual": token_ratio,
                "threshold": max_token_ratio,
                "operator": "<=",
                "evidence_class": evidence_class,
                "comparison_digest": comparison_digest,
            }
        )

        max_cost_ratio = policy["max_combined_cost_ratio_vs_previous"]
        if max_cost_ratio is not None:
            candidate_cost = finite_metric(
                candidate.get("usage", {}).get("combined", {}).get("cost_usd")
            )
            previous_cost = finite_metric(
                previous.get("usage", {}).get("combined", {}).get("cost_usd")
            )
            cost_ratio = (
                ratio(candidate_cost, previous_cost)
                if candidate_cost is not None and previous_cost is not None
                else None
            )
            checks.append(
                {
                    "gate": "max_combined_cost_ratio_vs_previous",
                    "status": (
                        "inconclusive"
                        if cost_ratio is None
                        else "failed"
                        if cost_ratio == "unbounded" or cost_ratio > max_cost_ratio
                        else "passed"
                    ),
                    "actual": cost_ratio,
                    "threshold": max_cost_ratio,
                    "operator": "<=",
                    "evidence_class": evidence_class,
                    "comparison_digest": comparison_digest,
                }
            )

    statuses = {check["status"] for check in checks}
    if "failed" in statuses:
        status = "rejected"
        exit_code = 1
    elif "inconclusive" in statuses:
        status = "inconclusive"
        exit_code = 3
    else:
        status = "eligible_for_human_approval"
        exit_code = 0
    decision = {
        "schema": (
            "workloop-promotion-decision/2"
            if policy_v2
            else "workloop-promotion-decision/1"
        ),
        "status": status,
        "promotion_authorized": False,
        "human_approval_required": True,
        "candidate_skill_digest": next(iter(candidate_digests)),
        "previous_skill_digest": next(iter(previous_digests)),
        "proposal_validation": selected_proposal_binding,
        "search_ledger": (
            {
                key: search_ledger[key]
                for key in (
                    "path",
                    "file_digest",
                    "head_digest",
                    "search_id",
                    "base_skill_digest",
                    "candidate_count",
                    "max_round",
                    "evidence_class_counts",
                    "resources",
                    "selected_candidate",
                )
            }
            if search_ledger is not None
            else None
        ),
        "observed_evidence_classes": observed_classes,
        "missing_evidence_classes": missing_classes,
        "policy": {
            "path": str(policy_path),
            "digest": file_digest(policy_path),
        },
        "comparisons": [
            {
                "path": item["_path"],
                "file_digest": item["_file_digest"],
                "digest": item["digest"],
                "evidence_class": item["compatible_envelope"]["dataset"][
                    "evidence_class"
                ],
            }
            for item in comparisons
        ],
        "checks": checks,
    }
    decision["digest"] = canonical_json_digest(decision)
    write_json(output, decision)
    print(f"decide-promotion: {status}: {output}")
    return exit_code


if __name__ == "__main__":
    raise SystemExit(main())
